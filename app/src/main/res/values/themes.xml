<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- 1. Base Theme: This is the main engine for your app's look -->
    <style name="Theme.Basilience" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Optional: You can keep this here as a backup,
             but your activity_main.xml background will cover it anyway -->
        <item name="android:windowBackground">@color/celadon</item>

        <!-- Status bar color to match your design -->
        <item name="statusBarBackground">@color/celadon</item>
    </style>

    <!-- 2. Splash Screen Theme: Keep this exactly as is -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/celadon</item>
        <item name="postSplashScreenTheme">@style/Theme.Basilience</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/animated_logo</item>
    </style>

    <!-- 3. Custom Component Styles (Keep these) -->
    <style name="InputFieldStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxBackgroundColor">@android:color/white</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="android:textColorHint">#A0A0A0</item>
        <item name="endIconTint">@color/primary</item>
    </style>

    <style name="FilterChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:backgroundTint">@null</item>
        <item name="android:textColor">#0F3B2E</item>
    </style>

    <style name="FilterChipSelected" parent="FilterChip">
        <item name="android:background">@drawable/bg_chip_selected</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="ScreenContainerCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:background">@drawable/top_rounded_white</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

</resources>